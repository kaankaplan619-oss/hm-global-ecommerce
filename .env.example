# ─────────────────────────────────────────────────────────────────────────────
# HM Global — Variables d'environnement (exemple)
#
# Copier ce fichier en `.env.local` et renseigner les valeurs réelles.
# NE JAMAIS committer `.env.local`. Les secrets de production vivent dans Vercel.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://hm-global.vercel.app

# ── Supabase (NE PAS modifier en production sans accord) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Fournisseurs / POD ────────────────────────────────────────────────────────
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=
PRINTIFY_API_TOKEN=
GELATO_API_KEY=
GELATO_API_BASE=
GELATO_PRODUCT_BASE=
TOPTEX_API_KEY=
TOPTEX_USERNAME=
TOPTEX_PASSWORD=
PRINTOCLOCK_USERNAME=
PRINTOCLOCK_PASSWORD=
PRINTOCLOCK_API_BASE=
PRINTOCLOCK_API_VERSION=

# ── Facturation (Pennylane) ────────────────────────────────────────────────────
PENNYLANE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Mockups universels + intégrations (mission mockups-universal)
# ─────────────────────────────────────────────────────────────────────────────

# Mockey.ai — génération de mockups print/merch.
# Laisser MOCKEY_API_KEY vide => le système retombe automatiquement sur le
# mockup statique (NEXT_PUBLIC_MOCKUP_FALLBACK_URL). Aucun crash.
MOCKEY_API_KEY=
# Base URL de l'API Mockey (override si l'endpoint diffère de la valeur par défaut).
MOCKEY_API_BASE=https://api.mockey.ai/v1
# Mockup de repli affiché côté client si l'API échoue ou n'est pas configurée.
NEXT_PUBLIC_MOCKUP_FALLBACK_URL=/images/mockups/placeholder.png

# Hermès OS — webhook sortant (cockpit interne).
# Laisser vide => les fonctions hermes.* deviennent des no-op (aucun appel réseau).
# Renseigner uniquement après validation humaine de la cible.
HERMES_WEBHOOK_URL=
# Secret optionnel signé en en-tête X-Hermes-Signature (HMAC-SHA256 du corps).
HERMES_WEBHOOK_SECRET=
# Mettre à 1 pour logguer les événements Hermès en local (debug).
HERMES_DEBUG=
